Checks: >
  -*,
  bugprone-assert-side-effect,
  bugprone-bool-pointer-implicit-conversion,
  bugprone-infinite-loop,
  bugprone-macro-repeated-side-effects,
  bugprone-misplaced-operator-in-strlen-in-alloc,
  bugprone-misplaced-pointer-arithmetic-in-alloc,
  bugprone-misplaced-widening-cast,
  bugprone-not-null-terminated-result,
  bugprone-signal-handler,
  bugprone-sizeof-expression,
  bugprone-suspicious-memory-comparison,
  bugprone-suspicious-memset-usage,
  bugprone-swapped-arguments,
  bugprone-undefined-memory-manipulation,
  bugprone-use-after-move,
  cert-err34-c,
  cert-msc50-cpp,
  cert-msc51-cpp,
  performance-noexcept-move-constructor
# Keep clang-tidy focused on deterministic source-level checks. Path-sensitive
# firmware analysis is covered by the separate GCC -fanalyzer CI job; enabling
# clang-analyzer-* here produces broad false positives in vendor HAL macros,
# setjmp-protected Lua paths, and GUI constructors that would require risky
# behavior-changing refactors to satisfy.
WarningsAsErrors: 'bugprone-*,cert-*,performance-*'
HeaderFilterRegex: '^(?!.*radio/src/(thirdparty|translations|tests)/).*radio/src/.*'
FormatStyle: none
