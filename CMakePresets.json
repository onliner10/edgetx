      "targets": [
        "fuzz-yaml-smoke"
      ]
    },
    {
      "name": "fuzz-mixer-smoke",
      "displayName": "Mixer Fuzzer Smoke",
      "configurePreset": "fuzzers",
      "targets": [
        "fuzz-mixer-smoke"
      ]
    },
    {
      "name": "fuzz-smoke",
      "displayName": "All Fuzzer Smoke Targets",
      "configurePreset": "fuzzers",
      "targets": [
        "fuzz-smoke"
      ]
    }
  ]
}
