{
  "version": 6,
  "configurePresets": [
    {
      "name": "firmware",
      "displayName": "Firmware",
      "binaryDir": "build/fw",
      "toolchainFile": "cmake/toolchain/arm-none-eabi.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": false
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "companion",
      "displayName": "Companion",
      "binaryDir": "build/companion",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "simu",
      "displayName": "SDL Simu",
      "binaryDir": "build/simu",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "san-asan-ubsan",
      "displayName": "Native ASan + UBSan Tests",
      "binaryDir": "build/san-asan-ubsan",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true,
        "DISABLE_COMPANION": true,
        "PCB": "X10",
        "PCBREV": "TX16S",
        "CMAKE_BUILD_TYPE": "Debug",
        "EDGE16_SANITIZERS": "address,undefined",
        "EDGE16_SAFETY_CHECKS": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "san-tsan",
      "displayName": "Native TSan Tests",
      "binaryDir": "build/san-tsan",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true,
        "DISABLE_COMPANION": true,
        "PCB": "X10",
        "PCBREV": "TX16S",
        "CMAKE_BUILD_TYPE": "Debug",
        "EDGE16_SANITIZERS": "thread",
        "EDGE16_SAFETY_CHECKS": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "san-msan",
      "displayName": "Native MSan Tests",
      "binaryDir": "build/san-msan",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true,
        "DISABLE_COMPANION": true,
        "PCB": "X10",
        "PCBREV": "TX16S",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "EDGE16_SANITIZERS": "memory",
        "EDGE16_SAFETY_CHECKS": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "fuzzers",
      "displayName": "Native Clang Fuzzers",
      "binaryDir": "build/fuzzers",
      "toolchainFile": "cmake/toolchain/native.cmake",
      "cacheVariables": {
        "EdgeTX_SUPERBUILD": false,
        "NATIVE_BUILD": true,
        "DISABLE_COMPANION": true,
        "PCB": "X10",
        "PCBREV": "TX16S",
        "CMAKE_BUILD_TYPE": "Debug",
        "EDGE16_BUILD_FUZZERS": true,
        "EDGE16_SANITIZERS": "address,undefined",
        "EDGE16_SAFETY_CHECKS": true
      },
      "warnings": {
        "dev": false
      }
    }
  ],
  "buildPresets": [
    {
      "name": "firmware",
      "displayName": "Firmware",
      "configurePreset": "firmware",
      "targets": [
        "firmware"
      ]
    },
    {
      "name": "companion",
      "displayName": "Companion",
      "configurePreset": "companion",
      "targets": [
        "companion"
      ]
    },
    {
      "name": "simu",
      "displayName": "SDL Simu",
      "configurePreset": "simu",
      "targets": [
        "simu"
      ]
    },
    {
      "name": "tests-radio",
      "displayName": "Radio Tests",
      "configurePreset": "simu",
      "targets": [
        "tests-radio"
      ]
    },
    {
      "name": "san-asan-ubsan",
      "displayName": "Native ASan + UBSan Tests",
      "configurePreset": "san-asan-ubsan",
      "targets": [
        "tests-radio"
      ]
    },
    {
      "name": "san-tsan",
      "displayName": "Native TSan Tests",
      "configurePreset": "san-tsan",
      "targets": [
        "tests-radio"
      ]
